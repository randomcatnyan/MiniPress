<!DOCTYPE html>
<html lang="fr">
	<head>
		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<title>MiniPress - Créer une catégorie</title>
	</head>
	<body>
		<header>
			<h1>MiniPress - Administration</h1>
		</header>

		<div class="container">
			<h2>Créer une catégorie</h2>

			{% if message %}
				<div class="alert alert-success">
					{{ message }}
				</div>
			{% endif %}

			{% if error %}
				<div class="alert alert-error">
					{{ error }}
				</div>
			{% endif %}

			<form method="POST" action="/categories/create">
				{{ csrf.field | raw }}

				<div class="form-group">
					<label for="titre">Titre
						<span class="required">*</span>
					</label>
					<input type="text" id="titre" name="titre" value="{{ old.titre ?? '' }}" placeholder="Nom de la catégorie" required>
				</div>

				<div class="form-group">
					<label for="description">Description</label>
					<textarea id="description" name="description" placeholder="Description de la catégorie (optionnel)">{{ old.description ?? '' }}</textarea>
				</div>

				<button type="submit">Créer la catégorie</button>
			</form>
		</div>
	</body>
</html>
